# =====================================================
# Biến môi trường bổ sung cho Docker Compose
# (các biến app chính nằm trong .env)
# Copy thành .env và điền giá trị nếu deploy lên server
# =====================================================

# URL API mà BROWSER gọi (build-time arg của frontend)
# Local:  http://localhost:8000
# Server: http://YOUR_SERVER_IP:8000
VITE_API_URL=http://localhost:8000

# Google OAuth (build-time arg của frontend)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:8000/users/oauth/google

# Typesense API Key (phải khớp với TYPESENSE_API_KEY trong .env)
TYPESENSE_API_KEY=medispace-ts-secret
