# =====================================================
# Biến môi trường bổ sung cho Docker Compose
# (các biến app chính nằm trong .env)
# Copy thành .env và điền giá trị nếu deploy lên server
# =====================================================

# URL API mà BROWSER gọi (build-time arg của frontend)
# Local:  http://localhost:8000
# Server: http://YOUR_SERVER_IP:8000
VITE_API_URL=http://localhost:8000

# Google OAuth (build-time arg của frontend)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:8000/users/oauth/google

# Typesense API Key (phải khớp với TYPESENSE_API_KEY trong .env)
TYPESENSE_API_KEY=medispace-ts-secret
TYPESENSE_AUTO_RECONCILE=true
TYPESENSE_EMBEDDING_ENABLED=true
TYPESENSE_RECREATE_ON_SCHEMA_MISMATCH=false
TYPESENSE_VECTOR_SEARCH=true

# Secret nội bộ dùng giữa Backend và ML recommendation service.
ML_SERVICE_TOKEN=replace-with-a-long-random-secret

# Media upload quality
MEDIA_IMAGE_JPEG_QUALITY=80
PRESCRIPTION_IMAGE_JPEG_QUALITY=95
PRESCRIPTION_OCR_MODE=parallel
PRESCRIPTION_OCR_SCAN_TIMEOUT_MS=220000
PRESCRIPTION_OCR_SCAN_RETRIES=6
PRESCRIPTION_SCAN_MAX_IMAGES=5

# Prescription OCR / Vision LLM
CUSTOM_LLM_MAX_TOKENS=4096
VISION_LLM_MODEL=gemma-4-e4b-it.gguf
VISION_LLM_TIMEOUT_SECONDS=45
VISION_JSON_NORMALIZE_TIMEOUT_SECONDS=25
VISION_JSON_NORMALIZE_RETRIES=1
VISION_BRANCH_TIMEOUT_SECONDS=160
OCR_RESPONSE_BUDGET_SECONDS=170
VISION_LLM_MAX_TOKENS=4096
VISION_LLM_FREEFORM_MAX_TOKENS=4096
VISION_LLM_FREEFORM_TEMPERATURE=0.30
VISION_LLM_RETRIES=2
VISION_LLM_RETRY_BACKOFF_SECONDS=1.5
VISION_EXTRACTION_STRATEGY=two_stage
VISION_STRUCTURED_FALLBACK_TWO_STAGE=true
VISION_SEND_ORIGINAL_UNDER_BYTES=8388608
VISION_IMAGE_MAX_SIDE=2560
VISION_IMAGE_JPEG_QUALITY=92
OCR_INCLUDE_CANDIDATES=false
PARALLEL_TRADITIONAL_LLM_FALLBACK=false
TRADITIONAL_EARLY_RETURN_MIN_SCORE=88
TRADITIONAL_EARLY_RETURN_MIN_MEDICATIONS=2
TRADITIONAL_SUSPICIOUS_QUANTITY_LIMIT=120

# Community AI moderation
# Bật auto review tin nhắn mới. Admin vẫn có thể chạy lại bằng nút AI review nếu các URL/model được cấu hình.
AI_MODERATION_ENABLED=false
AI_MODERATION_BASE_URL=http://localhost:8001/v1
AI_MODERATION_MODEL=gemma-4-e4b-it.gguf
AI_MODERATION_API_KEY=
# Nếu dùng LLM gateway nội bộ giống local, điền các biến CUSTOM_LLM_* này.
# AI moderation sẽ fallback sang CUSTOM_LLM_BASE_URL/CUSTOM_LLM_MODEL khi AI_MODERATION_BASE_URL/MODEL không được set.
CUSTOM_LLM_BASE_URL=https://llm.datateam.space
CUSTOM_LLM_MODEL=gemma-4-e4b-it.gguf
CUSTOM_LLM_API_KEY=
# Chỉ bật trong test/e2e để không gọi provider thật.
AI_MODERATION_MOCK=false
AI_MODERATION_TIMEOUT_MS=12000
AI_MODERATION_WORKER_INTERVAL_MS=5000
AI_MODERATION_HIDE_CONFIDENCE=0.78
AI_MODERATION_REVIEW_CONFIDENCE=0.55

# Community Video Events / LiveKit
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
LIVEKIT_WS_URL=wss://your-livekit-server.com
AGENDA_JOB_COLLECTION=agendaJobs
DB_COMMUNITY_VIDEO_EVENTS_COLLECTION=communityVideoEvents
DB_COMMUNITY_VIDEO_EVENT_REGISTRATIONS_COLLECTION=communityVideoEventRegistrations
DB_COMMUNITY_VIDEO_EVENT_QUESTIONS_COLLECTION=communityVideoEventQuestions
