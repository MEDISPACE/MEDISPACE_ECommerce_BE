# =====================================================
# Biến môi trường bổ sung cho Docker Compose
# (các biến app chính nằm trong .env)
# Copy thành .env và điền giá trị nếu deploy lên server
# =====================================================

# URL API mà BROWSER gọi (build-time arg của frontend)
# Local:  http://localhost:8000
# Server: http://YOUR_SERVER_IP:8000
VITE_API_URL=http://localhost:8000

# Google OAuth (build-time arg của frontend)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:8000/users/oauth/google

# Typesense API Key (phải khớp với TYPESENSE_API_KEY trong .env)
TYPESENSE_API_KEY=medispace-ts-secret

# Secret nội bộ dùng giữa Backend và ML recommendation service.
ML_SERVICE_TOKEN=replace-with-a-long-random-secret

# Community AI moderation
# Bật auto review tin nhắn mới. Admin vẫn có thể chạy lại bằng nút AI review nếu các URL/model được cấu hình.
AI_MODERATION_ENABLED=false
AI_MODERATION_BASE_URL=http://localhost:8001/v1
AI_MODERATION_MODEL=gemma-4-e4b-it.gguf
AI_MODERATION_API_KEY=
# Chỉ bật trong test/e2e để không gọi provider thật.
AI_MODERATION_MOCK=false
AI_MODERATION_TIMEOUT_MS=12000
AI_MODERATION_WORKER_INTERVAL_MS=5000
AI_MODERATION_HIDE_CONFIDENCE=0.78
AI_MODERATION_REVIEW_CONFIDENCE=0.55

# Community Video Events / LiveKit
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
LIVEKIT_WS_URL=wss://your-livekit-server.com
AGENDA_JOB_COLLECTION=agendaJobs
DB_COMMUNITY_VIDEO_EVENTS_COLLECTION=communityVideoEvents
DB_COMMUNITY_VIDEO_EVENT_REGISTRATIONS_COLLECTION=communityVideoEventRegistrations
DB_COMMUNITY_VIDEO_EVENT_QUESTIONS_COLLECTION=communityVideoEventQuestions
